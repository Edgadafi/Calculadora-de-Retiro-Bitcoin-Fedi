# Mercado Pago — copia a .env.local (local) o configura en Vercel → Environment Variables.
# Documentación: https://www.mercadopago.com.mx/developers/es/docs/credentials

# Obligatorio para /api/create-preference y /api/verify-mp-payment
# Usa credenciales de PRUEBA o PRODUCCIÓN según el entorno (no mezcles en el mismo deploy).
MERCADOPAGO_ACCESS_TOKEN=
# Opcional: solo si usas Bricks/tokenización en frontend
MERCADOPAGO_PUBLIC_KEY=

# URL pública del sitio (sin barra final). En Vercel suele inferirse; si falla, define:
# APP_BASE_URL=https://tu-dominio.vercel.app

# Precios Checkout Pro en MXN (ajusta a tu negocio)
MERCADOPAGO_PRICE_MONTHLY_MXN=20
MERCADOPAGO_PRICE_LIFETIME_MXN=200
