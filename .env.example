# Mercado Pago — copia a .env.local (local) o configura en Vercel → Environment Variables.
# Documentación: https://www.mercadopago.com.mx/developers/es/docs/credentials

# Access token: el PRIMER valor definido entre los dos gana (MERCADOPAGO_ACCESS_TOKEN, luego _TEST).
# - Producción: token live (cobro real; checkout "producción" salvo MERCADOPAGO_CHECKOUT_SANDBOX).
# - Pruebas: token TEST- (recomendado dejar producción vacío y usar solo _TEST en Preview o deploy de prueba).
# No mezcles probar pago con token TEST- y tarjeta bancaria real, ni token prod con "tarjatas" de prueba oficiales.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_ACCESS_TOKEN_TEST=

# true | false | sin definir — fuerza URL sandbox vs producción al elegir init_point.
# Si no se define, en create-preference se prefiere sandbox_init_point solo cuando el token empieza por TEST-.
# MERCADOPAGO_CHECKOUT_SANDBOX=true

# APP_BASE_URL — debe ser el origen https público (mismo dominio de la app). back_urls e IPN (notification_url)
# se construyen con esta base. Si el usuario paga y cierra el navegador antes de volver, la app no recibe
# payment_id en la URL: la activación en cliente se hace con checkMercadoPagoReturn; el webhook aún no persiste
# estado en servidor (ver api/mp-webhook.js).
# APP_BASE_URL=https://retirobtc.mx

# MERCADOPAGO_PUBLIC_KEY — solo si añades SDK Bricks/Wallet en el front.

# Debug en el navegador: añade ?mpdebug=1 a la URL; al pulsar un plan, la consola registrará checkout_url, etc. (solo front).

# Precios Checkout Pro (MXN)
MERCADOPAGO_PRICE_MONTHLY_MXN=20
MERCADOPAGO_PRICE_LIFETIME_MXN=200
